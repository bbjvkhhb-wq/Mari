<!DOCTYPE html>

<html lang="ar" dir="rtl">

<head>

  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>لوحة التحكم - بوت البرودكاست</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <link rel="stylesheet" href="/css/style.css">

</head>

<body>

  <div class="dashboard-container">

    <div class="sidebar">

      <div class="sidebar-header">

        <img src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : '/img/default-avatar.png' %>" alt="Avatar" class="avatar">

        <h5><%= user.username %></h5>

      </div>

      <ul class="sidebar-menu">

        <li class="active">

          <a href="/dashboard">

            <i class="fas fa-broadcast-tower"></i>

            <span>البرودكاست</span>

          </a>

        </li>

        <li>

          <a href="/logout">

            <i class="fas fa-sign-out-alt"></i>

            <span>تسجيل الخروج</span>

          </a>

        </li>

      </ul>

      <div class="sidebar-footer">

        <div class="bot-status <%= botStatus ? 'online' : 'offline' %>">

          <span class="status-dot"></span>

          <span class="status-text"><%= botStatus ? 'متصل' : 'غير متصل' %></span>

        </div>

      </div>

    </div>

    

    <div class="main-content">

      <div class="header">

        <h1>لوحة التحكم</h1>

      </div>

      

      <% if (success && success.length > 0) { %>

        <div class="alert alert-success alert-dismissible fade show" role="alert">

          <%= success %>

          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>

        </div>

      <% } %>

      

      <% if (error && error.length > 0) { %>

        <div class="alert alert-danger alert-dismissible fade show" role="alert">

          <%= error %>

          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>

        </div>

      <% } %>

      

      <div class="card broadcast-card">

        <div class="card-header">

          <h5><i class="fas fa-paper-plane me-2"></i>إرسال برودكاست</h5>

        </div>

        <div class="card-body">

          <form action="/broadcast" method="POST">

            <div class="mb-3">

              <label for="message" class="form-label">الرسالة</label>

              <textarea class="form-control" id="message" name="message" rows="5" required></textarea>

            </div>

            

            <div class="mb-3">

              <label class="form-label">نوع البرودكاست</label>

              <div class="broadcast-types">

                <div class="form-check">

                  <input class="form-check-input" type="radio" name="type" id="typeAll" value="all" checked>

                  <label class="form-check-label" for="typeAll">

                    <i class="fas fa-users me-1"></i> جميع الأعضاء

                  </label>

                </div>

                <div class="form-check">

                  <input class="form-check-input" type="radio" name="type" id="typeOnline" value="online">

                  <label class="form-check-label" for="typeOnline">

                    <i class="fas fa-circle text-success me-1"></i> الأعضاء المتصلين فقط

                  </label>

                </div>

                <div class="form-check">

                  <input class="form-check-input" type="radio" name="type" id="typeOffline" value="offline">

                  <label class="form-check-label" for="typeOffline">

                    <i class="fas fa-circle text-secondary me-1"></i> الأعضاء غير المتصلين فقط

                  </label>

                </div>

              </div>

            </div>

            

            <div class="mb-3">

              <label for="guildId" class="form-label">السيرفر</label>

              <select class="form-select" id="guildId" name="guildId">

                <option value="all">جميع السيرفرات</option>

                <% guilds.forEach(guild => { %>

                  <option value="<%= guild.id %>"><%= guild.name %> (<%= guild.memberCount %> عضو)</option>

                <% }); %>

              </select>

            </div>

            

            <button type="submit" class="btn btn-primary btn-lg w-100">

              <i class="fas fa-paper-plane me-2"></i> إرسال البرودكاست

            </button>

          </form>

        </div>

      </div>

      

      <div class="servers-grid">

        <% guilds.forEach(guild => { %>

          <div class="server-card">

            <div class="server-icon">

              <% if (guild.icon) { %>

                <img src="<%= guild.icon %>" alt="<%= guild.name %>">

              <% } else { %>

                <div class="default-icon">

                  <%= guild.name.charAt(0) %>

                </div>

              <% } %>

            </div>

            <div class="server-info">

              <h5><%= guild.name %></h5>

              <p><i class="fas fa-users me-1"></i> <%= guild.memberCount %> عضو</p>

            </div>

          </div>

        <% }); %>

      </div>

    </div>

  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
